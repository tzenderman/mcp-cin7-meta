# Required: Cin7 Core API credentials
CIN7_ACCOUNT_ID=your-account-id-here
CIN7_API_KEY=your-application-key-here

# Optional (with defaults)
CIN7_BASE_URL=https://inventory.dearsystems.com/ExternalApi/v2/
ISSUE_REPORT_PATH=./data/issue_reports.log

# Logging
MCP_LOG_LEVEL=INFO
MCP_LOG_FILE=

# Sessions
SESSION_ENABLED=true
SESSION_TTL_DAYS=30

# HTTP transport
SERVER_URL=http://localhost:3000
HOST=0.0.0.0
PORT=3000

# ScaleKit OAuth (optional — server runs without auth if these are blank)
SCALEKIT_ENVIRONMENT_URL=
SCALEKIT_CLIENT_ID=
SCALEKIT_CLIENT_SECRET=
SCALEKIT_RESOURCE_ID=
SCALEKIT_INTERCEPTOR_SECRET=

# Email allowlist for interceptors (comma-separated). Empty = allow all.
ALLOWED_EMAILS=
